# ── Auth: choose ONE of the two modes below ──────────────────────────────────

# Mode A — Google AI Studio (API key)
# Get a key at https://aistudio.google.com/apikey
GEMINI_API_KEY=

# Mode B — Vertex AI (Application Default Credentials)
# Set GCP_PROJECT_ID to enable; leave GEMINI_API_KEY empty.
# Authenticate locally with: gcloud auth application-default login
# On Cloud Run the service account is used automatically.
GCP_PROJECT_ID=
GCP_REGION=us-central1

# ── Model ─────────────────────────────────────────────────────────────────────
# GA recommended (native audio, VAD, affective dialog, tool use)
GEMINI_MODEL=gemini-live-2.5-flash-native-audio
# Cost-efficient preview alternative:
# GEMINI_MODEL=gemini-live-2.5-flash-preview-native-audio-09-2025

# ── Server ────────────────────────────────────────────────────────────────────
# Set MOCK_MODE=true to run without any credentials (demo mode)
MOCK_MODE=false
ALLOWED_ORIGINS=http://localhost:3000
