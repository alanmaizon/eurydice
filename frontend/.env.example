VITE_API_BASE_URL=http://localhost:8000
# Local dev only: forwarded to the backend in client.hello so the backend can
# open the Gemini Live native-audio session while still owning tools/state.
# Do not use this in production builds.
# VITE_GEMINI_API_KEY=your-local-gemini-api-key
# Optional overrides:
# VITE_RUNTIME_URL=http://localhost:8000/api/runtime
# VITE_LIVE_WS_URL=ws://localhost:8000/ws/live
